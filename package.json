{
  "name": "@marshell/chifu-wizard",
  "version": "0.1.3",
  "description": "One-command setup for chifu — installs the CLI, teaches your AI coding agent (Claude Code, Cursor, Windsurf) to check dependencies for CVEs, and saves your API key. Run with `bunx @marshell/chifu-wizard` or `npx @marshell/chifu-wizard`.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marshell-dev/chifu-wizard.git"
  },
  "homepage": "https://github.com/marshell-dev/chifu-wizard#readme",
  "bugs": {
    "url": "https://github.com/marshell-dev/chifu-wizard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "chifu-wizard": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "install.sh",
    "install.ps1",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/cli.ts",
    "agent": "bun run src/cli.ts --agent",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "chifu",
    "installer",
    "setup",
    "wizard",
    "cve",
    "dependencies",
    "security",
    "ai-agents",
    "claude-code",
    "cursor",
    "windsurf",
    "codex",
    "opencode",
    "gemini-cli",
    "cline",
    "agents-md",
    "skill"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "dotenv": "^17.2.3",
    "jsonc-parser": "^3.3.1",
    "open": "^10.1.0",
    "yargs": "^17.7.2",
    "zod": "^3.24.0"
  }
}
